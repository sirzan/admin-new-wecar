# =============================================
# Admin Panel - environment variables
# =============================================
# Copy this file to `.env` (NOT committed) and fill in the values.
# Run `supabase start` locally to obtain the local keys.

# ── Public Supabase (used in the browser) ───────────────────────────
# Local default (after `supabase start`):
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<replace-with-anon-key>

# ── Server-only Supabase (NEVER expose to the browser) ──────────────
# Used inside createServerFn handlers. Keep behind the server boundary.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<replace-with-service-role-key>

# ── Public wecar API (for admin -> wecar communication) ─────────────
# Base URL of the deployed wecar frontend that exposes /api/admin/*
WECAR_API_URL=http://localhost:5173
# Shared secret that wecar's /api/admin/* endpoints will require.
# Generate with: openssl rand -hex 32
WECAR_API_KEY=replace-with-shared-secret

# ── Admin bootstrap (only for first-time provisioning) ──────────────
# Optional: when invoking the admin-bootstrap Edge Function manually,
# you can hard-code the desired first admin here for scripts.
ADMIN_BOOTSTRAP_EMAIL=admin@wecar.mx
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=Admin Wecar
